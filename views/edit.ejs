<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit your chat</title>
</head>
<body>
    <p>Edit your chat: <%= chat._id %></p>
    <p>This chat was send from <b><%= chat.from %></b><b>to <%= chat.to %></b></p>

    <form method="POST" action="/chats/<%= chat._id %>?_method=PUT">
        <textarea name="message" rows="10" cols="50"><%= chat.message %></textarea>
        <button>Edit</button>
    </form>
</body>
</html>